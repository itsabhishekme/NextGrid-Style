{
  "name": "NextGrid Style Fashion",
  "short_name": "NextGrid",

  "description": "Luxury futuristic fashion ecommerce platform powered by Next.js and Capacitor.",

  "start_url": "/",

  "scope": "/",

  "display": "standalone",

  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],

  "background_color": "#000000",

  "theme_color": "#000000",

  "orientation": "portrait-primary",

  "lang": "en-US",

  "dir": "ltr",

  "categories": [
    "shopping",
    "fashion",
    "lifestyle"
  ],

  "prefer_related_applications": false,

  "screenshots": [
    {
      "src": "/screenshots/mobile-home.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "NextGrid mobile homepage"
    },

    {
      "src": "/screenshots/desktop-home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "NextGrid desktop homepage"
    }
  ],

  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },

    {
