{
  "id": "https://nextgridstyle.vercel.app/",
  "name": "NextGrid Style",
  "short_name": "NextGrid Style",

  "description": "Luxury futuristic fashion ecommerce platform powered by Next.js and Capacitor.",

  "start_url": "https://nextgridstyle.vercel.app/?source=pwa",

  "scope": "https://nextgridstyle.vercel.app/",

  "display": "standalone",

  "display_override": [
    "window-controls-overlay"
  ],

  "background_color": "#000000",
  "theme_color": "#000000",

  "orientation": "portrait-primary",

  "lang": "en-US",
  "dir": "ltr",

  "categories": [
    "shopping",
    "fashion",
    "lifestyle"
  ],

  "prefer_related_applications": false,

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "protocol_handlers": [
    {
      "protocol": "web+nextgrid",
      "url": "https://nextgridstyle.vercel.app/?url=%s"
    }
  ],

  "share_target": {
    "action": "https://nextgridstyle.vercel.app/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "screenshots": [
    {
      "src": "https://nextgridstyle.vercel.app/screenshots/mobile-home.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "NextGrid mobile homepage"
    },
    {
      "src": "https://nextgridstyle.vercel.app/screenshots/desktop-home.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "NextGrid desktop homepage"
    }
  ],

  "icons": [
    {
      "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-192.maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-192.maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-512.maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-512.maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name": "Luxury Collection",
      "short_name": "Luxury",
      "description": "Explore luxury fashion collection",
      "url": "https://nextgridstyle.vercel.app/luxury",
      "icons": [
        {
          "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-192.maskable.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Wishlist",
      "short_name": "Wishlist",
      "description": "View your wishlist",
      "url": "https://nextgridstyle.vercel.app/wishlist",
      "icons": [
        {
          "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-192.maskable.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Search Fashion",
      "short_name": "Search",
      "description": "Search latest fashion products",
      "url": "https://nextgridstyle.vercel.app/search",
      "icons": [
        {
          "src": "https://nextgridstyle.vercel.app/icons/manifest-icon-192.maskable.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
}